$TTL    604800
@       IN      SOA     dns-vb-1.example.com.   example.com. (
6       ; Serial
604800  ; Refresh
86400   ; Retry
2419200 ; Expire
604800 ) ; Negative Cache TTL

; name servers - NS records
 IN     NS      dns-vb-1.example.com.
; PTR Records
7.1     IN      PTR     dns-vb-1.example.com. ; 192.168.1.7
6.1     IN      PTR     app-vb-1.example.com. ; 192.168.1.6
8.1     IN      PTR     gitlab-vb-1.example.com. ; 192.168.1.8
9.1     IN      PTR     prometheus-vb-1.example.com. ; 192.168.1.9
10.1    IN      PTR     grafana-vb-1.example.com. ; 192.168.1.10
